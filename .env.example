# Application
PLL_ENVIRONMENT=development
PLL_LOG_LEVEL=INFO

# CORS(JSON 数组字面量)
PLL_CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# 前端打包产物路径(生产模式下被 FastAPI 静态托管)
PLL_FRONTEND_DIST_DIR=frontend/dist

# AI / Vision
PLL_AI_VISION_PROVIDER=fake          # fake | openai | qwen
PLL_OPENAI_API_KEY=
PLL_OPENAI_VISION_MODEL=gpt-4o-mini
PLL_OPENAI_REQUEST_TIMEOUT_S=20

# AI / LLM (Chat)
PLL_AI_LLM_PROVIDER=fake             # fake | openai | deepseek
PLL_OPENAI_MODEL_LLM=gpt-4o-mini

# AI / TTS (Text-to-Speech)
PLL_AI_TTS_PROVIDER=fake             # fake | openai | minimax
PLL_OPENAI_MODEL_TTS=tts-1-hd
PLL_OPENAI_TTS_VOICE=alloy

# AI / STT (Speech-to-Text)
PLL_AI_STT_PROVIDER=fake             # fake | openai
PLL_OPENAI_MODEL_STT=whisper-1

# AI / ImageGen (Image Generation)
PLL_AI_IMAGEGEN_PROVIDER=fake        # fake | openai | wanx

# Upload limits
PLL_UPLOAD_MAX_BYTES=8388608
PLL_UPLOAD_ALLOWED_MIME=["image/jpeg","image/png","image/webp"]

# Rate limit
PLL_RATE_LIMIT_VISION_PER_MIN=6
PLL_RATE_LIMIT_PERSONA_PER_MIN=10
PLL_RATE_LIMIT_CHAT_MESSAGES_PER_MIN=30

# === DeepSeek (LLM, OpenAI-compatible) ===
# Set PLL_AI_LLM_PROVIDER=deepseek to enable.
# PLL_DEEPSEEK_API_KEY=sk-...
# PLL_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# PLL_DEEPSEEK_MODEL_LLM=deepseek-v4-flash

# === Qwen-VL (Vision, DashScope compatible-mode) ===
# Set PLL_AI_VISION_PROVIDER=qwen to enable.
# Get key at https://dashscope.console.aliyun.com/.
# PLL_QWEN_API_KEY=sk-...
# PLL_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PLL_QWEN_MODEL_VISION=qwen-vl-max-latest

# === MiniMax (TTS, speech-02-hd) ===
# Set PLL_AI_TTS_PROVIDER=minimax to enable.
# PLL_MINIMAX_API_KEY=...
# PLL_MINIMAX_MODEL_TTS=speech-02-hd
# PLL_MINIMAX_DEFAULT_VOICE=English_expressive_narrator

# === Wanx (ImageGen, DashScope 通义万象) ===
# Set PLL_AI_IMAGEGEN_PROVIDER=wanx to enable.
# Uses same DashScope platform as Qwen; PLL_QWEN_API_KEY can be reused.
# Or set a dedicated key via PLL_WANX_API_KEY.
# Models: wanx2.1-t2i-turbo (fast, 0.14¥/img) | wanx2.1-t2i-plus (quality, 0.20¥/img)
# PLL_WANX_API_KEY=sk-...
# PLL_WANX_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc
# PLL_WANX_MODEL_IMAGEGEN=wanx2.1-t2i-plus
