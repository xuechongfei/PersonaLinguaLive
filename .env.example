# Application
PLL_ENVIRONMENT=development
PLL_LOG_LEVEL=INFO

# CORS(JSON 数组字面量)
PLL_CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# 前端打包产物路径(生产模式下被 FastAPI 静态托管)
PLL_FRONTEND_DIST_DIR=frontend/dist

# AI / Vision
PLL_AI_VISION_PROVIDER=fake          # fake | openai
PLL_OPENAI_API_KEY=
PLL_OPENAI_VISION_MODEL=gpt-4o-mini
PLL_OPENAI_REQUEST_TIMEOUT_S=20

# AI / LLM (Chat)
PLL_AI_LLM_PROVIDER=fake             # fake | openai
PLL_OPENAI_MODEL_LLM=gpt-4o-mini

# AI / TTS (Text-to-Speech)
PLL_AI_TTS_PROVIDER=fake             # fake | openai
PLL_OPENAI_MODEL_TTS=tts-1-hd
PLL_OPENAI_TTS_VOICE=alloy

# AI / STT (Speech-to-Text)
PLL_AI_STT_PROVIDER=fake             # fake | openai
PLL_OPENAI_MODEL_STT=whisper-1

# Upload limits
PLL_UPLOAD_MAX_BYTES=8388608
PLL_UPLOAD_ALLOWED_MIME=["image/jpeg","image/png","image/webp"]

# Rate limit
PLL_RATE_LIMIT_VISION_PER_MIN=6
PLL_RATE_LIMIT_PERSONA_PER_MIN=10
PLL_RATE_LIMIT_CHAT_MESSAGES_PER_MIN=30
